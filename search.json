---
layout: null
---
[
{% for article in site.articles %}
  {
    "title": {{ article.title | jsonify }},
    "url": "{{ article.url | relative_url }}",
    "date": "{{ article.date | date: '%Y-%m-%d' }}",
    "tags": {{ article.tags | jsonify }},
    "categories": {{ article.categories | jsonify }},
    "content": {{ article.content | strip_html | normalize_whitespace | truncatewords: 200 | jsonify }}
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
]
